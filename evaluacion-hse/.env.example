# === Backend de base de datos ===
# "json" para desarrollo local (guarda en ./data), "firestore" en producción (Cloud Run).
DB_BACKEND=json

# === Google Cloud / Firestore (solo en producción) ===
# En Cloud Run se toma automáticamente de la cuenta de servicio; localmente no hace falta.
GOOGLE_CLOUD_PROJECT=

# === Sesión del administrador ===
# Secreto para firmar la cookie de sesión. Genera uno largo y aleatorio.
SESSION_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# Credenciales del primer administrador (se crean al hacer seed si no existen).
ADMIN_USERNAME=Admin-Renergeia
ADMIN_PASSWORD=Renergeia2026*

# === Envío de correo (Resend) ===
RESEND_API_KEY=
# Remitente verificado en Resend (dominio btodigital.com).
MAIL_FROM="Renergeia Capacitaciones <no-reply@btodigital.com>"

# === App ===
# URL pública de la app (para enlaces en el correo). Ej. https://evaluacion-hse-xxxx.run.app
APP_BASE_URL=http://localhost:3000
